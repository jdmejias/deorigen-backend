generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ ENUMS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

enum Role {
  ADMIN
  FARMER
  BUYER
  PARTNER
  INVESTOR
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum FulfillmentType {
  LOCAL_WAREHOUSE
  FROM_COLOMBIA
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  FUNDED
  COMPLETED
  CANCELLED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum InvestmentStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ USERS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(BUYER)
  name         String?
  phone        String?
  avatar       String?
  locale       String   @default("es")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  farmerProfile  FarmerProfile?
  partnerProfile Partner?
  orders         Order[]
  cart           Cart?
  investments    Investment[]
  supportTickets SupportTicket[]

  @@index([role])
}

// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ FARMERS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model FarmerProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug        String   @unique
  bio         String?
  region      String?
  department  String?
  videoUrl    String?  // YouTube/Vimeo main video
  thumbnailUrl String?
  isActive    Boolean  @default(true)
  featuredFrom DateTime?
  featuredTo   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]
  media       Media[]
  projects    Project[]
  withdrawals Withdrawal[]
  availableBalance Decimal @default(0) @db.Decimal(12, 2)
  lockedBalance    Decimal @default(0) @db.Decimal(12, 2)

  @@index([isActive])
  @@index([featuredFrom, featuredTo])
  @@index([slug])
}

// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ CATEGORIES & BRANDS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  icon      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products  Product[]
}

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products  Product[]
}

// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ PRODUCTS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model Product {
  id              String   @id @default(uuid())
  farmerId        String
  farmer          FarmerProfile @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brandId         String?
  brand           Brand?    @relation(fields: [brandId], references: [id], onDelete: SetNull)
  name            String
  slug            String   @unique
  description     String?
  shortDescription String?
  price           Decimal  @db.Decimal(12, 2)
  compareAtPrice  Decimal? @db.Decimal(12, 2)
  currency        String   @default("EUR")
  weight          Decimal? @db.Decimal(8, 2)
  weightUnit      String   @default("g")
  sku             String?  @unique
  stock           Int      @default(0)
  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  isB2B           Boolean  @default(false)
  characteristics Json?    // flexible key-value (region, roast level, etc.)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  media           Media[]
  cartItems       CartItem[]
  orderItems      OrderItem[]
  inventoryItems  InventoryItem[]

  @@index([farmerId])
  @@index([categoryId])
  @@index([slug])
  @@index([isActive, isFeatured])
}

// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ MEDIA â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model Media {
  id         String   @id @default(uuid())
  farmerId   String?
  farmer     FarmerProfile? @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  productId  String?
  product    Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  url        String
  type       String   @default("image") // image | video
  altText    String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([farmerId])
  @@index([productId])
}

// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ CART â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model Cart {
  id        String     @id @default(uuid())
  userId    String?    @unique
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String?    @unique  // for guest carts
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  items     CartItem[]

  @@index([sessionId])
}

model CartItem {
  id              String   @id @default(uuid())
  cartId          String
  cart            Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity        Int      @default(1)
  fulfillmentType FulfillmentType @default(LOCAL_WAREHOUSE)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([cartId, productId, fulfillmentType])
  @@index([cartId])
}

// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ ORDERS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique
  userId          String?
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Guest info (when no user account)
  guestEmail      String?
  guestName       String?
  guestPhone      String?
  status          OrderStatus @default(PENDING)
  fulfillmentType FulfillmentType @default(LOCAL_WAREHOUSE)
  countryCode     String?
  // Shipping address
  shippingName    String?
  shippingAddress String?
  shippingCity    String?
  shippingState   String?
  shippingZip     String?
  shippingCountry String?
  shippingPhone   String?
  // Totals
  subtotal        Decimal     @db.Decimal(12, 2)
  shippingCost    Decimal     @default(0) @db.Decimal(12, 2)
  tax             Decimal     @default(0) @db.Decimal(12, 2)
  // BUY-01: voluntary support/"apoyo" contribution — not a physical item, not taxed
  supportAmount   Decimal     @default(0) @db.Decimal(12, 2)
  total           Decimal     @db.Decimal(12, 2)
  currency        String      @default("EUR")
  // QR & certificate
  qrCode          String?
  certificateUrl  String?
  thankYouVideoUrl String?
  // Timestamps
  paidAt          DateTime?
  shippedAt       DateTime?
    deliveredAt     DateTime?
    trackingNumber  String?
    createdAt       DateTime    @default(now())
    updatedAt       DateTime    @updatedAt

    items           OrderItem[]
    payments        Payment[]
  events          OrderEvent[]

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([guestEmail])
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  productName     String
  productSlug     String
  quantity        Int
  unitPrice       Decimal  @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)
  fulfillmentType FulfillmentType @default(LOCAL_WAREHOUSE)
  createdAt       DateTime @default(now())

  @@index([orderId])
}

model OrderEvent {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  createdAt DateTime @default(now())

  @@index([orderId])
}

// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ PAYMENTS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model Payment {
  id              String        @id @default(uuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  externalId      String?       // payment gateway reference
  provider        String?       // stripe, paypal, etc.
  method          String?
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("EUR")
  status          PaymentStatus @default(PENDING)
  rawResponse     Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([orderId])
  @@index([externalId])
}

// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ COUNTRIES & PARTNERS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model Country {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique // ISO 3166-1 alpha-2
  flag      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partners   Partner[]
  warehouses Warehouse[]

  @@index([code])
}

model Partner {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  countryId   String
  country     Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  companyName String?
  phone       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouses  Warehouse[]

  @@index([countryId])
}

model Warehouse {
  id        String   @id @default(uuid())
  partnerId String
  partner   Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  countryId String
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  name      String
  address   String?
  city      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventory InventoryItem[]

  @@index([partnerId])
  @@index([countryId])
}

model InventoryItem {
  id          String   @id @default(uuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Int       @default(0)
  minStock    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([warehouseId, productId])
  @@index([warehouseId])
  @@index([productId])
}

// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ INVESTMENT / PROJECTS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model Project {
  id          String        @id @default(uuid())
  farmerId    String
  farmer      FarmerProfile @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  title       String
  slug        String        @unique
  description String?
  goalAmount  Decimal       @db.Decimal(12, 2)
  raisedAmount Decimal      @default(0) @db.Decimal(12, 2)
  currency    String        @default("EUR")
  status      ProjectStatus @default(DRAFT)
  imageUrl    String?
  endsAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  investments Investment[]

  @@index([farmerId])
  @@index([status])
  @@index([slug])
}

model Investment {
  id        String           @id @default(uuid())
  projectId String
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Decimal          @db.Decimal(12, 2)
  currency  String           @default("EUR")
  status    InvestmentStatus @default(PENDING)
  note      String?
  createdAt DateTime         @default(now())

  @@index([projectId])
  @@index([userId])
  @@index([status])
}

// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ LEADS (MAYORISTA / PARTICIPAR) â”€â”€

model Lead {
  id          String   @id @default(uuid())
  type        String   // mayorista | participar
  company     String?
  name        String
  email       String
  phone       String?
  country     String?
  city        String?
  productInterest String?
  estimatedVolume String?
  message     String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([isRead])
}

// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ SUPPORT TICKETS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model SupportTicket {
  id        String       @id @default(uuid())
  userId    String?
  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  name      String
  email     String
  subject   String
  message   String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([status])
  @@index([userId])
}

// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ EMAIL LOG â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model EmailLog {
  id        String   @id @default(uuid())
  to        String
  subject   String
  body      String?
  status    String   @default("sent") // sent | failed
  error     String?
  createdAt DateTime @default(now())

  @@index([to])
}

// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ NEWS / NOVEDADES â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model Post {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String?
  imageUrl    String?
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isPublished])
}// ---------------------------- WITHDRAWALS ----------------------
model Withdrawal {
  id              String   @id @default(uuid())
  farmerId        String
  farmer          FarmerProfile @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @default("EUR")
  status          WithdrawalStatus @default(PENDING)
  bankAccountInfo String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([farmerId])
  @@index([status])
}


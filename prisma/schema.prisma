generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  FARMER
  BUYER
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(BUYER)
  name         String?
  phone        String?
  locale       String   @default("es")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}